generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  STARTER
  GROWTH
  PRO
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum IdentityType {
  ADDRESS
  DOMAIN
}

enum IdentityStatus {
  PENDING
  VERIFIED
  FAILED
}

enum ContactStatus {
  SUBSCRIBED
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
  PENDING_CONFIRM
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum RecipientStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum SuppressionReason {
  UNSUBSCRIBED
  HARD_BOUNCE
  COMPLAINT
  MANUAL
}

// ─── Auth (NextAuth v5) ─────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  passwordHash     String?
  emailVerified    DateTime?
  image            String?

  plan                 Plan      @default(FREE)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  billingInterval      String? // "month" | "year"
  paymentFailedAt      DateTime?

  monthlySendCount Int      @default(0)
  sendCountResetAt DateTime @default(now())
  accountRampLevel Int      @default(1)
  flaggedAt        DateTime?
  flagReason       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Workspace & membership ─────────────────────────────────────────────────

model Workspace {
  id                      String  @id @default(cuid())
  name                    String
  mailingAddress          String?
  timezone                String  @default("UTC")
  defaultSenderIdentityId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships      Membership[]
  invitations      Invitation[]
  senderIdentities SenderIdentity[]
  contacts         Contact[]
  tags             Tag[]
  segments         Segment[]
  signupForms      SignupForm[]
  templates        Template[]
  campaigns        Campaign[]
  suppressions     SuppressionEntry[]
}

model Membership {
  id          String         @id @default(cuid())
  userId      String
  workspaceId String
  role        MembershipRole @default(MEMBER)
  createdAt   DateTime       @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model Invitation {
  id          String         @id @default(cuid())
  workspaceId String
  email       String
  role        MembershipRole @default(MEMBER)
  token       String         @unique
  expiresAt   DateTime
  createdAt   DateTime       @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
}

// ─── Sender identities ──────────────────────────────────────────────────────

model SenderIdentity {
  id                String         @id @default(cuid())
  workspaceId       String
  type              IdentityType   @default(ADDRESS)
  value             String // email address or bare domain
  displayName       String?
  status            IdentityStatus @default(PENDING)
  verificationToken String?
  dkimTokens        Json? // for DOMAIN: the 3 DKIM CNAME tokens from SES
  isDefault         Boolean        @default(false)
  rewriteRequired   Boolean        @default(false)
  verifiedAt        DateTime?
  createdAt         DateTime       @default(now())

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@unique([workspaceId, value])
  @@index([workspaceId])
}

// ─── Audience ───────────────────────────────────────────────────────────────

model Contact {
  id           String        @id @default(cuid())
  workspaceId  String
  email        String
  firstName    String?
  lastName     String?
  customFields Json          @default("{}")
  status       ContactStatus @default(SUBSCRIBED)
  source       String? // "import" | "form:<slug>" | "manual" | "api"
  confirmToken String?       @unique

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  unsubscribedAt DateTime?

  workspace  Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tags       ContactTag[]
  recipients CampaignRecipient[]

  @@unique([workspaceId, email])
  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
}

model Tag {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String   @default("#4F46E5")
  createdAt   DateTime @default(now())

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts  ContactTag[]

  @@unique([workspaceId, name])
}

model ContactTag {
  contactId String
  tagId     String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
}

model Segment {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  rules       Json // { match: "all"|"any", conditions: [{field, operator, value}] }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@unique([workspaceId, name])
}

model SignupForm {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  fields      Json // [{key, label, type, required}]
  doubleOptIn Boolean  @default(false)
  hostedSlug  String   @unique
  tagIds      Json     @default("[]") // tags applied to new signups
  submitCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── Content ────────────────────────────────────────────────────────────────

model Template {
  id           String   @id @default(cuid())
  workspaceId  String
  name         String
  designJson   Json
  compiledHtml String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── Campaigns ──────────────────────────────────────────────────────────────

model Campaign {
  id               String         @id @default(cuid())
  workspaceId      String
  name             String
  status           CampaignStatus @default(DRAFT)
  senderIdentityId String?
  subject          String?
  previewText      String?
  designJson       Json?
  compiledHtml     String?        @db.Text
  rawHtmlMode      Boolean        @default(false)

  audienceType      String  @default("all") // "all" | "tags" | "segment"
  audienceTagIds    Json    @default("[]")
  audienceSegmentId String?

  scheduledAt DateTime?
  sentAt      DateTime?
  completedAt DateTime?
  pausedAt    DateTime?
  pauseReason String? // "manual" | "auto-bounce" | "auto-complaint"

  recipientCount   Int @default(0)
  sentCount        Int @default(0)
  deliveredCount   Int @default(0)
  openCount        Int @default(0)
  clickCount       Int @default(0)
  bounceCount      Int @default(0)
  complaintCount   Int @default(0)
  unsubscribeCount Int @default(0)
  failedCount      Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace      Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  senderIdentity SenderIdentity?     @relation(fields: [senderIdentityId], references: [id], onDelete: SetNull)
  segment        Segment?            @relation(fields: [audienceSegmentId], references: [id], onDelete: SetNull)
  recipients     CampaignRecipient[]
  links          CampaignLink[]

  @@index([workspaceId, status])
}

model CampaignRecipient {
  id         String          @id @default(cuid())
  campaignId String
  contactId  String
  email      String
  mergeData  Json            @default("{}")
  status     RecipientStatus @default(PENDING)

  sesMessageId   String?   @unique
  error          String?
  attemptCount   Int       @default(0)
  sentAt         DateTime?
  deliveredAt    DateTime?
  openedAt       DateTime?
  firstClickedAt DateTime?
  bouncedAt      DateTime?
  complainedAt   DateTime?
  unsubscribedAt DateTime?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  clicks   ClickEvent[]

  @@unique([campaignId, contactId])
  @@index([campaignId, status])
  @@index([email])
}

model CampaignLink {
  id         String   @id @default(cuid())
  campaignId String
  url        String   @db.Text
  index      Int
  clickCount Int      @default(0)
  uniqueClickCount Int @default(0)
  createdAt  DateTime @default(now())

  campaign Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  clicks   ClickEvent[]

  @@unique([campaignId, index])
}

model ClickEvent {
  id          String   @id @default(cuid())
  linkId      String
  recipientId String
  userAgent   String?
  createdAt   DateTime @default(now())

  link      CampaignLink      @relation(fields: [linkId], references: [id], onDelete: Cascade)
  recipient CampaignRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([recipientId])
}

// ─── Suppression ────────────────────────────────────────────────────────────

model SuppressionEntry {
  id          String            @id @default(cuid())
  workspaceId String
  email       String
  reason      SuppressionReason
  note        String?
  createdAt   DateTime          @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([email])
}

/// Platform-wide suppression: hard bounces and complaints apply to every
/// workspace — an address that hard-bounced anywhere is never mailed again.
model GlobalSuppression {
  id        String            @id @default(cuid())
  email     String            @unique
  reason    SuppressionReason
  createdAt DateTime          @default(now())
}

// ─── Webhook idempotency ────────────────────────────────────────────────────

model WebhookEvent {
  id          String   @id @default(cuid())
  source      String // "stripe" | "sns"
  externalId  String
  type        String
  processedAt DateTime @default(now())

  @@unique([source, externalId])
}
