# ── Core ────────────────────────────────────────────────────────────────────
# Public URL of the app (no trailing slash). Used in emails, links, webhooks.
APP_URL="http://localhost:3000"

# Postgres connection string (docker compose provides one automatically)
DATABASE_URL="postgresql://sendfable:sendfable@localhost:5432/sendfable?schema=public"

# Redis connection string (BullMQ queue + rate limiting)
REDIS_URL="redis://localhost:6379"

# ── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
# Auth.js v5: trust APP_URL / proxy Host headers (safe behind your own Caddy/HTTPS).
AUTH_TRUST_HOST="true"

# ── Amazon SES ──────────────────────────────────────────────────────────────
# Leave AWS keys BLANK for local dev: emails are logged to the console and
# written as .eml files to /tmp/outbox instead of being sent.
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# SES configuration set (must have an SNS event destination for
# Bounce/Complaint/Delivery events — see README).
SES_CONFIGURATION_SET="sendfable-events"

# SNS webhook signature verification. Default is strict (true).
# Set false only for local fixture tests without Amazon certs.
# SNS_VERIFY_STRICT="false"

# Early launch (production): close public signup, block real campaign sends without SES.
# EARLY_LAUNCH="true"
# ALLOW_PUBLIC_SIGNUP="false"
# Explicit campaign delivery gate (default false when unset). Independent of SES sandbox.
# CAMPAIGN_SEND_ENABLED="false"
# Admin-only SES infrastructure test script (scripts/ses-controlled-test.ts). Default false.
# SES_CONTROLLED_TEST_ENABLED="false"
# Platform admin UI (/admin) — defaults to first registered user if unset.
# PLATFORM_OWNER_EMAIL="chris@iscreamstudio.com"

# The platform's own verified sending domain. From-addresses on strict-DMARC
# providers (gmail.com etc.) are rewritten to localpart@this-domain.
PLATFORM_SEND_DOMAIN="send.sendfable.com"

# Ops alerting (scripts/ops-alert.js): owner email for monitor/backup alerts.
# Must be an SES-verified identity while the account is in sandbox.
OWNER_ALERT_EMAIL=""

# First-party analytics interface (src/lib/analytics.ts) — intentionally
# disabled until a provider is approved. See docs/ANALYTICS_DECISION.md.
ANALYTICS_ENABLED="false"

# ── Stripe ──────────────────────────────────────────────────────────────────
# Leave blank in dev to disable billing (everything else still works).
# Production: use sk_live_ / pk_live_ only. Never mix test price IDs with live keys.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_EXPECTED_ACCOUNT_ID=""
# Public Checkout gate (default false when unset).
STRIPE_BILLING_ENABLED="false"
# Owner-only controlled Checkout while public billing is off.
STRIPE_OWNER_TEST_ENABLED="false"

# Price IDs — created for you by: npm run stripe:setup
# Prefer *_ANNUAL; *_YEARLY is an alias accepted by the app.
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_STARTER_ANNUAL=""
STRIPE_PRICE_STARTER_YEARLY=""
STRIPE_PRICE_GROWTH_MONTHLY=""
STRIPE_PRICE_GROWTH_ANNUAL=""
STRIPE_PRICE_GROWTH_YEARLY=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_ANNUAL=""
STRIPE_PRICE_PRO_YEARLY=""

# ── Uploads (optional S3) ───────────────────────────────────────────────────
# If S3_BUCKET is blank, images are stored on the local /uploads volume.
S3_BUCKET=""
S3_REGION=""
S3_PUBLIC_URL=""

# ── Dev mail outbox ─────────────────────────────────────────────────────────
# Where .eml files are written when AWS credentials are absent.
# Defaults to /tmp/outbox (or %TEMP%\outbox on Windows).
# OUTBOX_DIR="/tmp/outbox"

# Worker concurrency (BullMQ)
# WORKER_CONCURRENCY="5"
